{
  "rewrites": [
    {
      "source": "/f1-news",
      "destination": "https://www.formula1.com/en/latest/all.xml"
    },
    {
      "source": "/f1-article/:path*",
      "destination": "https://www.formula1.com/:path*"
    },
    {
      "source": "/live",
      "destination": "/live.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/race/:season/:slug",
      "destination": "/race/:season/:slug/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
